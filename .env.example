# Cisco Catalyst SD-WAN MCP Server
# Copy to .env and set your vManage credentials

# Required: vManage hostname or IP
VMANAGE_HOST=your-vmanage.example.com

# Required: vManage credentials (used for API authentication)
VMANAGE_USERNAME=admin
VMANAGE_PASSWORD=your_password

# Optional: Port (default 443 for HTTPS)
VMANAGE_PORT=443

# Optional: Use JWT authentication (default true, recommended for vManage 20.18.1+)
# Set to false to use session-based (JSESSIONID) authentication
VMANAGE_USE_JWT=true
